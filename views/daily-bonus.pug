section.main-container.bonus
  - var title = "daily bonus";
  - var detail = "claim a bonus every day";
  - var amount = userBonus.reward + " USDT";
  - var streak = userBonus.day + " / 7";
  - var claimed = userBonus.day;
  - var left = 7 - userBonus.day;
  .gift-box
    img.gift(src="/images/logo/gift.png" alt="Daily Reward Gift")
    .confetti

  .progress-bar
    each num in [1,2,3,4,5,6,7]
      .circle(class=(num <= claimed ? "active" : "")) #{num}

  .reward-text
    p Your daily reward:
    h2= amount
    p.info Come back tomorrow to get your bonus points. 
      | Skipping a day resets your check-in.

  if isBonusSet
    button.continue-btn(onclick="frameToggle('window','bonus')") Bonus claimed
  else
    button.continue-btn(onclick=`dailyBonus(${isBonusSet})`) Continue